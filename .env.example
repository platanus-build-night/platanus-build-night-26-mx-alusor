# ── DocToApp env ─────────────────────────────────────────────
# Copy to .env.local and fill in. Never commit .env.local.

# ── Needed for the core flow (dev) ───────────────────────────
# Anthropic API key — Managed Agent (build engine) + Sonnet orchestrator.
# Create at https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# MongoDB Atlas connection string (use a SEPARATE cluster/db from prod).
# db name defaults to "doctoapp" in lib/mongodb.ts
MONGODB_URI="mongodb+srv://USER:PASS@CLUSTER.mongodb.net/?retryWrites=true&w=majority"

# Vercel Blob — stores the uploaded .docx + the generated index.html.
# Local: `vercel link` then `vercel env pull`. Or create a Blob store in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Needed only for DEPLOY (fire-and-forget completion webhook) ──
# whsec_ secret shown once when you create the webhook in the Console.
# Subscribe to: session.status_idled, session.status_terminated
# Dev: not required (synchronous re-tail path); use ngrok if you want to test it locally.
ANTHROPIC_WEBHOOK_SIGNING_KEY=whsec_...

# Optional: reuse a pre-created Managed Agent / Environment instead of create-or-reuse at runtime.
# ANTHROPIC_AGENT_ID=
# ANTHROPIC_ENVIRONMENT_ID=

# ── Auth: Clerk ──────────────────────────────────────────────
# Gates /panel + /builder + build APIs (see src/proxy.ts). Public: / , /d/[slug],
# /api/webhooks/anthropic. Get keys from the Clerk dashboard (or the `clerk` CLI).
# The publishable key is PUBLIC (shipped to the browser) and is read at BUILD time,
# so it must be present when `next build` runs on the host.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Optional (clerk init sets sensible defaults if omitted):
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
